# ─────────────────────────────────────────────────
# Supabase
# Get these from: https://supabase.com/dashboard → your project → Settings → API
# ─────────────────────────────────────────────────

# Public anon key (safe to expose client-side)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ─────────────────────────────────────────────────
# App URL
# ─────────────────────────────────────────────────

# Local dev
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Production — set this in Vercel env vars
# NEXT_PUBLIC_SITE_URL=https://joinbeez.com

# ─────────────────────────────────────────────────
# NOTE: Never add SUPABASE_SERVICE_ROLE_KEY here.
# Service role key grants full DB access — never expose it client-side.
# Use it only in server-side API routes if strictly necessary,
# stored as a non-NEXT_PUBLIC_ env var.
# ─────────────────────────────────────────────────
