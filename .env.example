# ─────────────────────────────────────────────────
# Supabase
# Get these from: https://supabase.com/dashboard → your project → Settings → API
# ─────────────────────────────────────────────────

# Public anon key (safe to expose client-side)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ─────────────────────────────────────────────────
# App URL
# ─────────────────────────────────────────────────

# Local dev
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Production — set this in Vercel env vars
# NEXT_PUBLIC_SITE_URL=https://joinbeez.com

# ─────────────────────────────────────────────────
# Supabase service role key (server-side only — NEVER expose client-side)
# Find it at: Supabase dashboard → your project → Settings → API → service_role key
# Used in: app/api/send-welcome-email/route.ts
# ─────────────────────────────────────────────────

SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ─────────────────────────────────────────────────
# Email provider (optional — needed to actually send welcome emails)
# Uncomment and fill in whichever provider you use (Resend recommended).
# See: app/api/send-welcome-email/route.ts for integration instructions.
# ─────────────────────────────────────────────────

# RESEND_API_KEY=re_your-key-here
